# Copy to `.env` ON THE VPS and fill in. NEVER commit the real .env
# (the repo auto-commits/pushes — .env is gitignored as a safety net).
#
# Generate the Mastodon secrets ONCE on the box after building the image
# (`docker compose build world1`), then paste the outputs below:
#
#   docker run --rm corda-mastodon:local bundle exec rake secret      # SECRET_KEY_BASE
#   docker run --rm corda-mastodon:local bundle exec rake secret      # OTP_SECRET (run again)
#   docker run --rm corda-mastodon:local bundle exec rake mastodon:webpush:generate_vapid_key
#   docker run --rm -e SECRET_KEY_BASE=placeholder corda-mastodon:local \
#       bundle exec rake db:encryption:init

POSTGRES_PASSWORD=

SECRET_KEY_BASE=
OTP_SECRET=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

OPENAI_BASE_URL=
OPENAI_API_KEY=
